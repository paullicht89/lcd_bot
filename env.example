# LCD Teams Bot environment template

# Bot Framework identity.
# For this internal company bot, use SingleTenant unless Microsoft/admin policy says otherwise.
MicrosoftAppType=SingleTenant
MicrosoftAppId=
MicrosoftAppPassword=
MicrosoftAppTenantId=

# Server.
BOT_HOST=127.0.0.1
BOT_PORT=3978
BOT_PUBLIC_BASE_URL=https://lcdbot.lcd.nyc
LOG_LEVEL=INFO

# Optional Microsoft Graph integration for future commands.
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
GRAPH_SCOPE=https://graph.microsoft.com/.default

# Optional external APIs for future commands.
CONNECTEAM_API_KEY=
NYS_APP_TOKEN=

# Local development.
ENVIRONMENT=local
